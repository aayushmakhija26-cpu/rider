{
  "private": true,
  "packageManager": "pnpm@10.30.1",
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:ci": "next dev --hostname 127.0.0.1 --port 3001",
    "start:ci": "next start --hostname 127.0.0.1 --port 3001",
    "build": "prisma generate && next build",
    "ci:build": "prisma generate && next build",
    "ci:prisma": "node ./scripts/ci/prisma-migration-check.mjs",
    "ci:test": "vitest run --pool=threads --exclude tests/a11y/**",
    "ci:a11y": "playwright test --config=playwright.config.ts",
    "ci:a11y:server": "prisma generate && next build && next start --hostname 127.0.0.1 --port 3001",
    "start": "next start",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "test": "vitest run --pool=threads --exclude tests/a11y/**",
    "test:watch": "vitest",
    "test:a11y": "playwright test --config=playwright.config.ts"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "@prisma/adapter-neon": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "bcryptjs": "^3.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jose": "^6.0.11",
    "lucide-react": "^0.511.0",
    "next": "15.6.0-canary.59",
    "radix-ui": "^1.4.2",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "server-only": "^0.0.1",
    "stripe": "^18.1.0",
    "swr": "^2.3.3",
    "tailwind-merge": "^3.3.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "4.1.7",
    "@types/node": "^22.15.18",
    "@types/react": "19.1.4",
    "@types/react-dom": "19.1.5",
    "autoprefixer": "^10.4.21",
    "dotenv": "^16.5.0",
    "postcss": "^8.5.3",
    "prisma": "^7.5.0",
    "tailwindcss": "4.1.7",
    "tw-animate-css": "^1.3.0",
    "typescript": "^5.8.3",
    "vitest": "^4.1.1"
  }
}
