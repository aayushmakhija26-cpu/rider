# Neon PostgreSQL - Pooled connection (used by Prisma for queries)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# Neon PostgreSQL - Direct connection (used by Prisma for migrations)
DIRECT_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# Stripe
STRIPE_SECRET_KEY=sk_test_***
STRIPE_WEBHOOK_SECRET=whsec_***
BASE_URL=http://localhost:3000

# Auth (JWT signing)
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Apple Sign In with Apple
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
# Note: Apple requires HTTPS for redirect_uri — use ngrok or a Vercel Preview for local testing
